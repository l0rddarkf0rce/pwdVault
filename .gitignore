# ------------------------------------------------------------
# Python / virtual‑environment generated files
# ------------------------------------------------------------
# Byte‑compiled / optimized / C extensions
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
*.manifest
*.spec
pip-wheel-metadata/
*.whl

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------------------------------------
# Virtual environment directories (if you ever commit one)
# ------------------------------------------------------------
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# ------------------------------------------------------------
# IDE / editor specific files
# ------------------------------------------------------------
# VS Code
.vscode/
# PyCharm / IntelliJ
.idea/
# Sublime Text
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------
# OS‑specific artefacts
# ------------------------------------------------------------
.DS_Store           # macOS Finder metadata
Thumbs.db           # Windows Explorer thumbnail cache
ehthumbs.db
Desktop.ini

# ------------------------------------------------------------
# Test / coverage artefacts
# ------------------------------------------------------------
htmlcov/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
pytest_cache/
.pytest_cache/
unittest.xml

# ------------------------------------------------------------
# MyPy type‑checking cache
# ------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json

# ------------------------------------------------------------
# Static analysis / linting caches
# ------------------------------------------------------------
ruff_cache/
flake8stats
pylint-report.txt
pylint-output.txt

# ------------------------------------------------------------
# Miscellaneous temporary files
# ------------------------------------------------------------
*.log
*.tmp
*.swp
*~
.*.swp
.*.swo
*.bak
*.orig

# ------------------------------------------------------------
# Secrets / configuration files that should be generated at runtime
# ------------------------------------------------------------
passwords.json      # the vault file (generated on first run)
passwords.json.bak  # backup of the vault file
*.key
*.enc
.env                # if you ever store environment variables locally
